# Copy this file to srcs/.env and fill in real values.
# srcs/.env MUST be gitignored.

DOMAIN_NAME=fbartole.42.fr

# MariaDB
MYSQL_DATABASE=wordpress
MYSQL_USER=wp_user

# WordPress
WP_TITLE=Inception
WP_URL=https://fbartole.42.fr

# WordPress administrator (cannot contain "admin" / "Admin" / "administrator")
WP_ADMIN_USER=fbart
WP_ADMIN_EMAIL=fbart@fbartole.42.fr

# WordPress secondary user
WP_USER=editor
WP_USER_EMAIL=editor@fbartole.42.fr

# Passwords are read from Docker secrets, NOT from this file:
#   secrets/db_root_password.txt
#   secrets/db_password.txt
#   secrets/wp_admin_password.txt
#   secrets/wp_user_password.txt
